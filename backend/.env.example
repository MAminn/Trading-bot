# Backend (trading bot) environment variables
# Copy this file to ".env" and fill in real values. Do NOT commit the real .env.
# All variables are optional; live_code.py falls back to built-in defaults if unset.

# Binance REST endpoints
BINANCE_BASE_URL=
BINANCE_FUTURES_BASE_URL=

# Email alert credentials (Gmail SMTP app password recommended)
LIVE_EMAIL_ADDRESS=
LIVE_EMAIL_APP_PASSWORD=
