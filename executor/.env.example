# Allowed values: OFF, TESTNET_READ, TESTNET_TRADE, LIVE_READ, LIVE_DRYRUN, LIVE
# WARNING: only OFF and TESTNET_READ are implemented in this build —
# any other value is refused and the executor exits with code 1.
EXECUTION_MODE=OFF

# Testnet-only credentials from https://testnet.binancefuture.com (never use live keys here).
# Required when EXECUTION_MODE=TESTNET_READ.
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
